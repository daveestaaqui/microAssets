{
    "manifest_version": 2,
    "name": "Jira Declutter \u2014 Board Simplifier",
    "version": "1.0.5",
    "description": "Hides distracting UI elements on Jira boards and issue pages to create a cleaner, focused project management view.",
    "homepage_url": "https://sporlyworks.com",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.atlassian.net/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "browser_action": {
        "default_popup": "popup/index.html",
        "default_title": "Jira Declutter",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "jira-declutter@omnisuite.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}