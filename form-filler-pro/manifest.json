{
  "manifest_version": 3,
  "name": "Smart Form Filler Pro",
  "version": "1.2.1",
  "description": "Auto-fill forms with saved profiles. Create multiple identities for testing. Supports all standard HTML form fields.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Form Filler",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png",
    "32": "icon32.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open Smart Form Filler Pro"
    }
  }
}