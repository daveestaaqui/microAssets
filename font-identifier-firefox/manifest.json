{
  "manifest_version": 2,
  "name": "Font Identifier & CSS Inspector",
  "version": "1.2.0",
  "description": "Hover over any text to identify the font family, size, weight, line-height, and color. Essential for designers.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Font Identifier",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "font-identifier@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}