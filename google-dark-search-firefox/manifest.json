{
    "manifest_version": 2,
    "name": "Dark Search \u2014 Google Night Mode",
    "version": "1.0.5",
    "description": "Applies a dark theme to Google Search results pages. Toggle the dark mode on or off from the extension popup.",
    "homepage_url": "https://sporlyworks.com",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://www.google.com/*",
                "*://www.google.co.uk/*",
                "*://www.google.ca/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "browser_action": {
        "default_popup": "popup/index.html",
        "default_title": "Google Dark Search",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "google-dark-search@omnisuite.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}