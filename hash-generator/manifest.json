{
  "manifest_version": 3,
  "name": "Hash Generator \u2014 SHA256 & MD5 Tool",
  "version": "1.2.1",
  "description": "Generate MD5, SHA-1, SHA-256 hashes from any text. Copy with one click.",
  "homepage_url": "https://sporlyworks.com",
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open Hash Generator \u2014 SHA256 & MD5 Tool"
    }
  }
}