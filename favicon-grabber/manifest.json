{
    "manifest_version": 3,
    "name": "Favicon Grabber \u2014 Site Icon Extractor",
    "version": "1.0.5",
    "description": "Extract favicons from any website. Download in multiple sizes or copy the URL.",
    "homepage_url": "https://sporlyworks.com",
    "action": {
        "default_popup": "popup/index.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "permissions": [
        "activeTab",
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y",
                "mac": "MacCtrl+Shift+Y"
            },
            "description": "Open Favicon Grabber \u2014 Site Icon Extractor"
        }
    }
}