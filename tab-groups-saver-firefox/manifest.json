{
    "manifest_version": 2,
    "name": "Tab Groups Saver & Restorer",
    "version": "1.0.5",
    "description": "Save your current tabs as named groups. Restore any saved session with one click. Never lose your workflow again.",
    "homepage_url": "https://sporlyworks.com",
    "permissions": [
        "tabs",
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_action": {
        "default_popup": "popup/index.html",
        "default_title": "Tab Groups Saver",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "tab-groups-saver@omnisuite.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}