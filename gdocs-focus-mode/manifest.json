{
  "manifest_version": 3,
  "name": "Docs Focus Mode \u2014 Distraction Blocker",
  "version": "1.2.1",
  "description": "Hide Google Docs menus, toolbars, and sidebars with one click to enter a clean, distraction-free writing environment.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Google Docs Focus Mode",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://docs.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open Docs Focus Mode \u2014 Distraction Blocker"
    }
  }
}