{
  "manifest_version": 2,
  "name": "Smart Form Filler Pro",
  "version": "1.1.0",
  "description": "Auto-fill forms with saved profiles. Create multiple identities for testing. Supports all standard HTML form fields.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Form Filler",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "form-filler-pro@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}