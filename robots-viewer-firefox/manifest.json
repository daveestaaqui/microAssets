{
    "manifest_version": 2,
    "name": "Robots.txt Viewer \u2014 SEO Inspector",
    "version": "1.0.5",
    "description": "View and analyze any website robots.txt file. Check crawl rules, sitemaps, and blocked paths.",
    "homepage_url": "https://sporlyworks.com",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_action": {
        "default_popup": "popup/index.html",
        "default_title": "Robots",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "robots-viewer@omnisuite.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}