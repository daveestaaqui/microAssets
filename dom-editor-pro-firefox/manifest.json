{
  "manifest_version": 2,
  "name": "Live DOM Editor Pro",
  "version": "1.2.0",
  "description": "Edit any webpage live. Change text, colors, layouts, and styles in real-time. Save snapshots and export changes.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "DOM Editor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "dom-editor-pro@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}