{
    "manifest_version": 3,
    "name": "Instagram Web Clean Feed",
    "version": "1.0.5",
    "description": "Hides suggested posts, Reels, and sponsored content from your Instagram web feed to show only posts from accounts you follow.",
    "homepage_url": "https://sporlyworks.com",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://www.instagram.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/index.html",
        "default_title": "Instagram Web Clean Feed",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y",
                "mac": "MacCtrl+Shift+Y"
            },
            "description": "Open Instagram Web Clean Feed"
        }
    }
}