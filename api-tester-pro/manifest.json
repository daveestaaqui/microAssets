{
  "manifest_version": 3,
  "name": "API Tester Pro \u2014 REST Client",
  "version": "1.2.1",
  "description": "Test REST APIs from your browser. Send GET, POST, PUT, DELETE requests with headers and body. View formatted responses.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "API Tester Pro",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png",
    "32": "icon32.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open API Tester Pro \u2014 REST Client"
    }
  }
}