{
  "manifest_version": 2,
  "name": "Base64 Encoder & Decoder Tool",
  "version": "1.1.0",
  "description": "Encode and decode Base64 strings instantly. Supports text and data URLs. Copy results with one click.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Base64 Tool",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "base64-encoder@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}