{
  "manifest_version": 2,
  "name": "Website Change Monitor Pro",
  "version": "1.2.0",
  "description": "Monitor any webpage for changes. Get notified when prices drop, content updates, or pages go down. Set check intervals.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "scripts": [
      "background/sw.js"
    ],
    "service_worker": "background.js"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Site Monitor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "website-monitor-pro@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}