{
  "manifest_version": 3,
  "name": "Lorem Ipsum & Placeholder Text",
  "version": "1.0.6",
  "description": "Generate lorem ipsum paragraphs, sentences, or words instantly. Copy to clipboard with one click.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Lorem Ipsum",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open Lorem Ipsum & Placeholder Text"
    }
  }
}