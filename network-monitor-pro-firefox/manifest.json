{
  "manifest_version": 2,
  "name": "Network Request Monitor Pro",
  "version": "1.1.0",
  "description": "Monitor all network requests in real-time. Filter by type, status, domain. Measure load times and find bottlenecks.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "webRequest",
    "storage",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": [
      "background/sw.js"
    ],
    "service_worker": "background.js"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Network Monitor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "network-monitor-pro@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}