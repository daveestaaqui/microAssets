{
  "manifest_version": 3,
  "name": "JWT Decoder \u2014 Token Inspector",
  "version": "1.2.1",
  "description": "Decode JSON Web Tokens instantly. View header, payload, and expiration without external tools.",
  "homepage_url": "https://sporlyworks.com",
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open JWT Decoder \u2014 Token Inspector"
    }
  }
}