{
    "manifest_version": 2,
    "name": "Text Diff Viewer \u2014 Side-by-Side Compare",
    "version": "1.0.5",
    "description": "Compare two text blocks side by side. Highlights additions, deletions, and changes instantly.",
    "homepage_url": "https://sporlyworks.com",
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_action": {
        "default_popup": "popup/index.html",
        "default_title": "Diff",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "diff-viewer@omnisuite.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}