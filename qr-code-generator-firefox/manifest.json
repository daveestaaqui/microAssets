{
    "manifest_version": 2,
    "name": "QR Code Generator - Instant URL to QR",
    "version": "1.0.5",
    "description": "Generate a QR code for any URL or text instantly. Download as PNG or copy to clipboard with one click from any web page.",
    "homepage_url": "https://sporlyworks.com",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_action": {
        "default_popup": "popup/index.html",
        "default_title": "QR Code Generator",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "qr-code-generator@omnisuite.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}