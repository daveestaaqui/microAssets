{
  "manifest_version": 2,
  "name": "Clipboard History Manager",
  "version": "1.1.0",
  "description": "Keep a searchable history of everything you copy. Access your clipboard history from any tab with one click.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage",
    "clipboardRead"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Clipboard History",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "clipboard-history@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}