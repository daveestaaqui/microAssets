{
  "manifest_version": 2,
  "name": "Color Picker Eyedropper & Palette Extractor",
  "version": "1.2.0",
  "description": "Pick any color from any web page with a crosshair eyedropper. Copies HEX, RGB, and HSL values to your clipboard instantly.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Color Picker Eyedropper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "color-picker-eyedropper@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}