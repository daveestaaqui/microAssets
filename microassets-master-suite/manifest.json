{
  "manifest_version": 3,
  "name": "OmniSuite Dev Toolkit",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "All 5 premium B2B tools in one extension. WCAG Auditing, Privacy Scanning, Contract Highlighting, Invoice & Time.",
  "homepage_url": "https://sporlyworks.com",
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "wcag_auditor_content.js",
        "privacy_scanner_content.js",
        "contract_highlighter_content.js",
        "invoice_extractor_content.js",
        "time_tracker_content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "time_tracker_background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open OmniSuite Dev Toolkit"
    }
  }
}