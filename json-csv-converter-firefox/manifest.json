{
  "manifest_version": 2,
  "name": "JSON to CSV Converter",
  "version": "1.2.0",
  "description": "Convert JSON arrays to CSV format instantly. Paste JSON, get CSV. Download or copy to clipboard.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "JSON\u2194CSV",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "json-csv-converter@omnisuite.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}