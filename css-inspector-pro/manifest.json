{
  "manifest_version": 3,
  "name": "CSS Inspector Pro",
  "version": "1.2.1",
  "description": "Inspect CSS properties of any element with one click. Copy styles, view computed values, and compare elements.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "CSS Inspector",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png",
    "32": "icon32.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open CSS Inspector Pro"
    }
  }
}