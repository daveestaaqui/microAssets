{
  "manifest_version": 3,
  "name": "Markdown Preview \u2014 Live Renderer",
  "version": "1.2.1",
  "description": "Preview Markdown files in your browser with GitHub-flavored styling, syntax highlighting, and tables.",
  "homepage_url": "https://sporlyworks.com",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Markdown",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open Markdown Preview \u2014 Live Renderer"
    }
  }
}