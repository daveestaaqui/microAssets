{
    "manifest_version": 2,
    "name": "Cookie Manager & Viewer",
    "version": "1.0.5",
    "description": "View, edit, and delete cookies for any website. Search and filter cookies with one click.",
    "homepage_url": "https://sporlyworks.com",
    "permissions": [
        "cookies",
        "activeTab",
        "<all_urls>",
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_action": {
        "default_popup": "popup/index.html",
        "default_title": "Cookies",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "cookie-manager@omnisuite.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}